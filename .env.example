# Скопируйте этот файл в .env и впишите свой бесплатный ключ.
# Получить ключ: https://console.groq.com (вход по email/Google, без карты).
GROQ_API_KEY=

# Опционально: переопределить модель, если у Groq поменялись имена free-tier моделей.
# Актуальный список: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
